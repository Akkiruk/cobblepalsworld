{
  "schemaVersion": 1,
  "id": "cobblepalsworld",
  "version": "${version}",
  "name": "CobblePals World",
  "description": "Pokémon-powered modular automation. Assign Tags to your Pokémon and watch them work.",
  "authors": [
    "Akkiruk"
  ],
  "contact": {
    "issues": "https://github.com/Akkiruk/cobblepalsworld/issues",
    "sources": "https://github.com/Akkiruk/cobblepalsworld"
  },
  "license": "MPL-2.0",
  "icon": "assets/cobblepalsworld/icon.png",
  "environment": "*",
  "entrypoints": {
    "main": [
      {
        "value": "com.cobblepalsworld.fabric.CobblePalsWorldFabric",
        "adapter": "kotlin"
      }
    ],
    "client": [
      {
        "value": "com.cobblepalsworld.fabric.CobblePalsWorldFabricClient",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "cobblepalsworld.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.16.14",
    "fabric-language-kotlin": "*",
    "minecraft": "~1.21.1",
    "java": ">=21",
    "cobblemon": ">=1.7.0"
  }
}
